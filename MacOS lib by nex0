-- Утилита для создания UI
local function Create(className, properties)
    local inst = Instance.new(className)
    for k, v in pairs(properties or {}) do inst[k] = v end
    return inst
end

-- Функция загрузки иконок по URL (Требует функции экзекутора)
local function FetchIcon(icon)
    if not icon then return "" end
    if type(icon) == "number" or (type(icon) == "string" and icon:match("^%d+$")) then return "rbxassetid://" .. icon end
    if type(icon) == "string" and icon:find("http") then
        local getasset = getcustomasset or getsynasset
        if writefile and getasset then
            local filename = "macos_icon_" .. icon:gsub("[^%w]", ""):sub(-20) .. ".png"
            if not isfile(filename) then pcall(function() writefile(filename, game:HttpGet(icon)) end) end
            return getasset(filename)
        end
        return ""
    end return icon
end

local function Tween(obj, props, time)
    local tween = TweenService:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), props)
    tween:Play() return tween
end

