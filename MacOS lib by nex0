            Create("UICorner", {Parent = Preview, CornerRadius = UDim.new(0, 4)}) Create("UIStroke", {Parent = Preview, Color = Color3.fromRGB(200, 200, 200), Thickness = 1})

            local PickerArea = Create("Frame", {Parent = CFrame, Size = UDim2.new(1, 0, 0, 100), Position = UDim2.new(0, 0, 0, 42), BackgroundTransparency = 1})
            local function MakeSlider(y, prefix, col, startVal)
                local B = Create("TextButton", {Parent = PickerArea, Size = UDim2.new(1, -30, 0, 6), Position = UDim2.new(0, 15, 0, y), BackgroundColor3 = Color3.fromRGB(235, 235, 235), Text = ""}) Create("UICorner", {Parent = B, CornerRadius = UDim.new(1,0)})
                local F = Create("Frame", {Parent = B, Size = UDim2.new(startVal/255, 0, 1, 0), BackgroundColor3 = col}) Create("UICorner", {Parent = F, CornerRadius = UDim.new(1,0)})
                return B, F
            end
            local RBtn, RFill = MakeSlider(15, "R", Color3.fromRGB(255, 70, 70), color.R*255)
            local GBtn, GFill = MakeSlider(45, "G", Color3.fromRGB(70, 255, 70), color.G*255)
            local BBtn, BFill = MakeSlider(75, "B", Color3.fromRGB(70, 70, 255), color.B*255)

            local function UpdateColor()
                color = Color3.fromRGB(RFill.Size.X.Scale*255, GFill.Size.X.Scale*255, BFill.Size.X.Scale*255)
                Preview.BackgroundColor3 = color
                if cfg.Callback then pcall(cfg.Callback, color) end
            end

            for _, slider in pairs({ {RBtn, RFill}, {GBtn, GFill}, {BBtn, BFill} }) do
