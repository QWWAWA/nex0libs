            local function RefreshSize() Tween(LFrame, {Size = UDim2.new(1, 0, 0, 42 + math.min(#listItems * 25, 120))}, 0.2) end
            local function RenderList()
                for _, v in pairs(ListScroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
                for i, item in ipairs(listItems) do
                    local itmF = Create("Frame", {Parent = ListScroll, Size = UDim2.new(1, 0, 0, 25), BackgroundTransparency = 1})
                    Create("TextLabel", {Parent = itmF, Size = UDim2.new(1, -40, 1, 0), Position = UDim2.new(0, 15, 0, 0), BackgroundTransparency = 1, Text = "- " .. item, Font = Enum.Font.Gotham, TextSize = 12, TextColor3 = Color3.fromRGB(100, 100, 100), TextXAlignment = Enum.TextXAlignment.Left})
                    local DelBtn = Create("TextButton", {Parent = itmF, Size = UDim2.new(0, 20, 0, 20), Position = UDim2.new(1, -30, 0.5, -10), BackgroundTransparency = 1, Text = "x", Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = Color3.fromRGB(255, 80, 80)})
                    DelBtn.MouseButton1Click:Connect(function() table.remove(listItems, i); RenderList(); RefreshSize() if cfg.Callback then pcall(cfg.Callback, listItems) end end)
                end RefreshSize()
            end

            AddBtn.MouseButton1Click:Connect(function()
                if Input.Text ~= "" then table.insert(listItems, Input.Text); Input.Text = ""; RenderList(); RefreshSize(); if cfg.Callback then pcall(cfg.Callback, listItems) end end
            end)
            RenderList()
            return WrapElement(LFrame)
        end

        function TabData:CreateButton(cfg)
            local BFrame = Create("Frame", {Parent = TabPage, Size = UDim2.new(1, 0, 0, 42), BackgroundColor3 = Color3.fromRGB(255, 255, 255)}) Create("UICorner", {Parent = BFrame, CornerRadius = UDim.new(0, 8)}) Create("UIStroke", {Parent = BFrame, Color = Color3.fromRGB(230, 230, 230), Thickness = 1})
            local Btn = Create("TextButton", {Parent = BFrame, Size = UDim2.new(1, -30, 0, 30), Position = UDim2.new(0, 15, 0.5, -15), BackgroundColor3 = config.Accent, Text = cfg.Name, Font = Enum.Font.GothamMedium, TextSize = 13, TextColor3 = Color3.fromRGB(255, 255, 255)})
            Create("UICorner", {Parent = Btn, CornerRadius = UDim.new(0, 6)})
            Btn.MouseButton1Click:Connect(function() if cfg.Callback then pcall(cfg.Callback) end end)
            return WrapElement(BFrame)
        end

        return TabData
    end
    return WindowData
end
