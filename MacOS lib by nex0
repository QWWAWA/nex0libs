            local color = cfg.Default or Color3.fromRGB(255, 255, 255)
            local CFrame = Create("Frame", {Parent = TabPage, Size = UDim2.new(1, 0, 0, 42), BackgroundColor3 = Color3.fromRGB(255, 255, 255), ClipsDescendants = true})
            Create("UICorner", {Parent = CFrame, CornerRadius = UDim.new(0, 8)}) Create("UIStroke", {Parent = CFrame, Color = Color3.fromRGB(230, 230, 230), Thickness = 1})
            
            local TopBtn = Create("TextButton", {Parent = CFrame, Size = UDim2.new(1, 0, 0, 42), BackgroundTransparency = 1, Text = ""})
            Create("TextLabel", {Parent = TopBtn, Size = UDim2.new(1, -100, 1, 0), Position = UDim2.new(0, 15, 0, 0), BackgroundTransparency = 1, Text = cfg.Name, Font = Enum.Font.GothamMedium, TextSize = 13, TextColor3 = Color3.fromRGB(50, 50, 50), TextXAlignment = Enum.TextXAlignment.Left})
